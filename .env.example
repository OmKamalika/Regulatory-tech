# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regtech_db

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_FRAMES=frames
MINIO_BUCKET_DOCUMENTS=documents

# Weaviate Vector Database
WEAVIATE_URL=http://localhost:8080

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Model Settings
WHISPER_MODEL=medium  # Options: tiny, small, medium, large
YOLO_MODEL=yolov8n.pt  # Options: yolov8n, yolov8s, yolov8m, yolov8l, yolov8x
EMBEDDING_MODEL=all-mpnet-base-v2  # sentence-transformers model
OCR_LANGUAGES=en  # Comma-separated language codes for EasyOCR

# Application Settings
APP_NAME=Regtech Video Compliance
DEBUG=True
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Upload
MAX_UPLOAD_SIZE=5368709120  # 5GB in bytes
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,mkv,webm

# Processing
FRAME_EXTRACTION_FPS=1  # Extract 1 frame per second
ENABLE_SCENE_DETECTION=True
MAX_CONCURRENT_JOBS=3

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
