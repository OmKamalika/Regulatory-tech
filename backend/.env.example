# ============================================================
# Regtech Video Compliance — Environment Configuration
# Copy this file to .env and rename it:
#   Windows: copy .env.example .env
#
# The values below work as-is for local development with
# Docker Desktop. Only change them for production.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=Regtech Video Compliance
DEBUG=False
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- API Authentication ---
# Leave empty for local dev (no auth required).
# Set a secret token for production.
API_KEY=

# --- Database ---
# Docker default: postgres user/password, port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/regtech_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- MinIO Object Storage ---
# Docker default credentials
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_FRAMES=frames
MINIO_BUCKET_DOCUMENTS=documents
MINIO_SECURE=False

# --- Weaviate Vector DB ---
WEAVIATE_URL=http://localhost:8080

# --- Ollama LLM + Vision ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Qwen2-VL for OCR on video frames. Pull with:
#   docker exec -it regtech_ollama ollama pull qwen2-vl:7b
# Set to "" to skip Qwen and fall back to EasyOCR.
OLLAMA_OCR_MODEL=qwen2-vl:7b

# --- AI Models ---
WHISPER_MODEL=medium
YOLO_MODEL=yolov8n.pt
EMBEDDING_MODEL=all-mpnet-base-v2
OCR_LANGUAGES=en

# --- Security ---
# These values are fine for local dev only. Generate real ones for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=local-dev-only-change-in-production
JWT_SECRET_KEY=local-dev-only-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- File Upload ---
MAX_UPLOAD_SIZE=5368709120
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,mkv,webm

# --- Processing ---
FRAME_EXTRACTION_FPS=1
ENABLE_SCENE_DETECTION=True
MAX_CONCURRENT_JOBS=3
